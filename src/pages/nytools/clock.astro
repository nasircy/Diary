---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="FocusClock | N-Diary">
  <div class="focusclock-page">
    <div class="mac-window">
      <header class="mac-header">
        <div class="window-controls">
          <div class="btn-macos close"></div>
          <div class="btn-macos minimize"></div>
          <div class="btn-macos maximize"></div>
        </div>

        <nav class="segmented-control">
          <button class="segment" data-target="alarms-view">Alarms</button>
          <button class="segment active" data-target="timers-view">Timers</button>
        </nav>

        <button class="add-btn" id="header-add-btn">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        </button>
      </header>

      <main class="mac-content">
        <div id="alarms-view" class="view">
          <div class="alarms-dashboard">
            <div id="alarms-grid" class="alarms-grid">
              <div class="empty-state" id="empty-alarms">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.2)" stroke-width="1"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                <p>No active alarms</p>
              </div>
            </div>
          </div>
        </div>

        <div id="timers-view" class="view active">
          <div class="elegant-setup-container">
            <div class="setup-main-time">
              <input type="number" id="input-h" value="" placeholder="00" min="0" max="99" onfocus="this.select()" title="Hours">
              <span class="delimiter">:</span>
              <input type="number" id="input-m" value="" placeholder="00" min="0" max="59" onfocus="this.select()" title="Minutes">
              <span class="delimiter">:</span>
              <input type="number" id="input-s" value="" placeholder="00" min="0" max="59" onfocus="this.select()" title="Seconds">
            </div>

            <div class="setup-options glass-panel">
              <div class="option-row">
                <label>Label</label>
                <input type="text" id="setup-label" class="invisible-input" placeholder="Timer">
              </div>
              <div class="separator"></div>
              <div class="option-row">
                <label>When Timer Ends</label>
                <select id="setup-sound" class="invisible-select">
                  <option value="gentle">Gentle</option>
                  <option value="beep">Beep</option>
                  <option value="chime">Chime</option>
                  <option value="alert">Alert</option>
                </select>
              </div>
            </div>

            <button class="pill-btn start-big hover-bounce" id="start-btn">Start</button>

            <div class="recents-minimal">
              <h4 class="recents-min-title">Recents</h4>
              <div id="recent-timers-list" class="recents-min-list"></div>
            </div>
          </div>
        </div>

        <div id="focus-view" class="view">
          <div class="timer-ring-container">
            <svg class="timer-ring" width="500" height="500">
              <circle class="ring-bg" stroke-width="8" fill="transparent" r="230" cx="250" cy="250"/>
              <circle class="ring-progress" stroke-width="8" fill="transparent" r="230" cx="250" cy="250"/>
            </svg>

            <div class="timer-info-inside">
              <div class="end-time hover-bounce">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right:4px"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
                <span id="end-time-display">--:--</span>
              </div>
              <div class="main-time" id="focus-time-display">00:00</div>
              <div class="timer-label" id="focus-label">Timer</div>
              <div class="sound-selector hover-bounce">
                <select id="focus-sound-select" class="invisible-select-dark">
                  <option value="gentle">Gentle</option>
                  <option value="beep">Beep</option>
                  <option value="chime">Chime</option>
                  <option value="alert">Alert</option>
                </select>
              </div>
            </div>
          </div>

          <div class="timer-controls">
            <button class="pill-btn cancel hover-bounce" id="cancel-btn">Cancel</button>
            <button class="pill-btn pause hover-bounce" id="pause-btn">Pause</button>
          </div>
        </div>
      </main>

      <footer class="mac-footer">
        Copyright 2026 Nasir
      </footer>
    </div>
  </div>
</BaseLayout>

<style>
  :root {
    --mac-bg: #1e1e1e;
    --mac-text: #ffffff;
    --mac-text-muted: #8e8e93;
    --mac-segment-bg: rgba(60, 60, 60, 0.4);
    --mac-segment-active: rgba(100, 100, 100, 0.7);
    --mac-segment-border: rgba(0, 0, 0, 0.2);
    --timer-orange: #FF9F0A;
    --pill-cancel: #3a3a3c;
    --pill-cancel-hover: #48484a;
    --circle-track: #333333;
    --glass-bg: rgba(40, 40, 42, 0.5);
    --glass-border: rgba(255, 255, 255, 0.1);
  }

  .focusclock-page {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 100vh;
    background: #000;
    padding: 0;
  }

  .mac-window {
    width: 100vw;
    height: 100vh;
    background-color: var(--mac-bg);
    display: flex;
    flex-direction: column;
    position: relative;
    backdrop-filter: blur(40px);
    -webkit-backdrop-filter: blur(40px);
  }

  @media (min-width: 1000px) {
    .focusclock-page { padding: 40px 0; }
    .mac-window {
      width: 1000px;
      height: 750px;
      border-radius: 12px;
      box-shadow: 0 40px 80px rgba(0,0,0,0.6), inset 0 1px 0 rgba(255,255,255,0.05);
      border: 1px solid rgba(0,0,0,0.8);
    }
  }

  .hover-bounce {
    transition: transform 0.2s cubic-bezier(0.2, 0.8, 0.2, 1), opacity 0.2s;
  }
  .hover-bounce:active {
    transform: scale(0.95);
    opacity: 0.8;
  }

  .mac-header {
    height: 52px;
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
  }

  .window-controls {
    position: absolute;
    left: 20px;
    display: flex;
    gap: 8px;
  }
  .btn-macos {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }
  .btn-macos.close { background-color: #FF5F56; }
  .btn-macos.minimize { background-color: #FFBD2E; }
  .btn-macos.maximize { background-color: #27C93F; }

  .segmented-control {
    background-color: var(--mac-segment-bg);
    border-radius: 7px;
    display: flex;
    padding: 2px;
    border: 1px solid var(--mac-segment-border);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
  }

  .segment {
    background: transparent;
    border: none;
    color: var(--mac-text);
    padding: 4px 14px;
    font-size: 13px;
    border-radius: 5px;
    cursor: pointer;
    font-weight: 500;
    transition: background-color 0.2s, color 0.2s;
    opacity: 0.7;
  }
  .segment.active {
    background-color: var(--mac-segment-active);
    box-shadow: 0 1px 2px rgba(0,0,0,0.3);
    opacity: 1;
  }

  .add-btn {
    position: absolute;
    right: 20px;
    background: transparent;
    border: none;
    color: var(--mac-text-muted);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.2s, transform 0.2s;
  }
  .add-btn:hover { color: var(--mac-text); }
  .add-btn:active { transform: scale(0.9); }

  .mac-content {
    flex: 1;
    position: relative;
    overflow: hidden;
  }

  .view {
    display: none;
    width: 100%;
    height: 100%;
    animation: fadeIn 0.3s ease;
  }
  .view.active { display: flex; }

  @keyframes fadeIn {
    from { opacity: 0; transform: scale(0.98); }
    to { opacity: 1; transform: scale(1); }
  }

  .elegant-setup-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    padding: 0 20px;
  }

  .setup-main-time {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 40px;
  }

  .setup-main-time :global(input) {
    background: transparent;
    border: none;
    color: #fff;
    font-size: 80px;
    font-weight: 200;
    width: 90px;
    text-align: center;
    outline: none;
    line-height: 1;
  }
  .setup-main-time :global(input::placeholder) { color: rgba(255,255,255,0.2); }
  .delimiter {
    font-size: 65px;
    font-weight: 200;
    color: rgba(255,255,255,0.4);
    margin: 0 5px;
    padding-bottom: 12px;
  }

  .glass-panel {
    background-color: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: 14px;
    width: 100%;
    max-width: 320px;
    display: flex;
    flex-direction: column;
    backdrop-filter: blur(30px);
    -webkit-backdrop-filter: blur(30px);
    margin-bottom: 30px;
  }

  .option-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 16px;
  }

  .option-row label {
    font-size: 14px;
    color: #fff;
    font-weight: 400;
  }

  .invisible-input {
    background: transparent;
    border: none;
    color: var(--mac-text-muted);
    font-size: 14px;
    text-align: right;
    outline: none;
    width: 120px;
  }
  .invisible-input::placeholder { color: rgba(255,255,255,0.3); }

  .invisible-select {
    appearance: none;
    -webkit-appearance: none;
    background: transparent;
    border: none;
    color: var(--mac-text-muted);
    font-size: 14px;
    text-align: right;
    outline: none;
    cursor: pointer;
    background-image: url('data:image/svg+xml;utf8,<svg fill="%238e8e93" height="14" viewBox="0 0 24 24" width="14" xmlns="http://www.w3.org/2000/svg"><path d="M7 10l5 5 5-5z"/></svg>');
    background-repeat: no-repeat;
    background-position: right center;
    padding-right: 18px;
  }

  .separator {
    height: 1px;
    background-color: rgba(255, 255, 255, 0.08);
    margin-left: 16px;
  }

  .start-big {
    background-color: rgba(52, 199, 89, 0.2);
    color: #34C759;
    width: 140px;
    height: 36px;
    font-size: 14px;
    border-radius: 17px;
    border: none;
    font-weight: 500;
    cursor: pointer;
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .start-big:hover { background-color: rgba(52, 199, 89, 0.3); }

  .recents-minimal {
    margin-top: 40px;
    width: 100%;
    max-width: 320px;
  }

  .recents-min-title {
    font-size: 12px;
    color: rgba(255, 255, 255, 0.4);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 12px;
    margin-left: 4px;
  }

  .recents-min-list {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .recent-bubble {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background-color: rgba(255, 255, 255, 0.04);
    border-radius: 10px;
    padding: 10px 14px;
    cursor: pointer;
    transition: background-color 0.2s;
  }
  .recent-bubble:hover { background-color: rgba(255, 255, 255, 0.08); }

  .rb-info { display: flex; align-items: center; gap: 12px; }
  .rb-time { font-size: 16px; font-weight: 300; }
  .rb-label { font-size: 13px; color: var(--mac-text-muted); }
  .rb-play { color: var(--timer-orange); opacity: 0.8; }

  .alarms-dashboard {
    width: 100%;
    height: 100%;
    overflow-y: auto;
    padding: 30px;
  }

  .alarms-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 25px;
    align-content: start;
  }

  .empty-state {
    grid-column: 1 / -1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 300px;
    color: rgba(255, 255, 255, 0.2);
    gap: 15px;
  }

  .dash-card {
    background-color: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: 16px;
    padding: 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    cursor: pointer;
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
  }
  .dash-card:hover {
    background-color: rgba(50, 50, 52, 0.6);
  }

  .dash-ring-container {
    position: relative;
    width: 110px;
    height: 110px;
    margin-bottom: 15px;
  }
  .dash-svg { transform: rotate(-90deg); width: 100%; height: 100%; }
  .dash-bg { stroke: var(--circle-track); }
  .dash-progress {
    stroke: var(--timer-orange);
    stroke-dasharray: 314;
    stroke-dashoffset: 0;
    stroke-linecap: round;
    transition: stroke-dashoffset 1s linear;
  }

  .dash-time-inside {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    font-size: 24px;
    font-weight: 300;
  }

  .dash-label {
    font-size: 15px;
    color: #fff;
    font-weight: 500;
    margin-bottom: 6px;
    text-align: center;
  }
  .dash-end {
    font-size: 12px;
    color: var(--mac-text-muted);
  }

  #focus-view {
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  .timer-ring-container {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
    margin-bottom: 50px;
  }

  .timer-ring { transform: rotate(-90deg); }
  .ring-bg { stroke: var(--circle-track); }
  .ring-progress {
    stroke: var(--timer-orange);
    stroke-dasharray: 1445;
    stroke-dashoffset: 0;
    stroke-linecap: round;
    transition: stroke-dashoffset 1s linear;
  }

  .timer-info-inside {
    position: absolute;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 100%;
  }

  .end-time {
    display: flex;
    align-items: center;
    color: var(--mac-text-muted);
    font-size: 16px;
    margin-bottom: -5px;
  }

  .main-time {
    font-size: 100px;
    font-weight: 200;
    letter-spacing: -1px;
    font-variant-numeric: tabular-nums;
    margin: 10px 0;
  }

  .timer-label {
    color: var(--mac-text-muted);
    font-size: 16px;
    margin-bottom: 8px;
  }

  .invisible-select-dark {
    appearance: none;
    -webkit-appearance: none;
    background-color: rgba(0,0,0,0.3);
    border: 1px solid rgba(255,255,255,0.1);
    color: #fff;
    padding: 6px 26px 6px 14px;
    border-radius: 6px;
    font-size: 14px;
    cursor: pointer;
    font-weight: 500;
    background-image: url('data:image/svg+xml;utf8,<svg fill="white" height="14" viewBox="0 0 24 24" width="14" xmlns="http://www.w3.org/2000/svg"><path d="M7 10l5 5 5-5z"/></svg>');
    background-repeat: no-repeat;
    background-position: right 8px center;
  }
  .invisible-select-dark:focus { outline: none; border-color: rgba(255,255,255,0.3); }

  .timer-controls {
    display: flex;
    gap: 20px;
  }

  .pill-btn {
    width: 120px;
    height: 34px;
    border-radius: 17px;
    border: none;
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .pill-btn.cancel {
    background-color: var(--pill-cancel);
    color: var(--mac-text);
  }
  .pill-btn.cancel:hover { background-color: var(--pill-cancel-hover); }

  .pill-btn.pause {
    background-color: rgba(255, 159, 10, 0.2);
    color: var(--timer-orange);
  }
  .pill-btn.pause:hover { background-color: rgba(255, 159, 10, 0.3); }

  .mac-footer {
    height: 30px;
    display: flex;
    justify-content: center;
    align-items: center;
    color: rgba(255,255,255,0.3);
    font-size: 11px;
    border-top: 1px solid rgba(255,255,255,0.05);
  }
</style>

<script>
  function generateBeep(freq: number, duration: number, type: OscillatorType = 'sine') {
    const audioCtx = new (window.AudioContext || (window as any).webkitAudioContext)();
    const oscillator = audioCtx.createOscillator();
    const gainNode = audioCtx.createGain();
    oscillator.type = type;
    oscillator.frequency.setValueAtTime(freq, audioCtx.currentTime);
    gainNode.gain.setValueAtTime(0.3, audioCtx.currentTime);
    gainNode.gain.exponentialRampToValueAtTime(0.01, audioCtx.currentTime + duration);
    oscillator.connect(gainNode);
    gainNode.connect(audioCtx.destination);
    oscillator.start();
    oscillator.stop(audioCtx.currentTime + duration);
  }

  const sounds: Record<string, () => void> = {
    gentle: () => {
      generateBeep(523, 0.3);
      setTimeout(() => generateBeep(659, 0.3), 300);
      setTimeout(() => generateBeep(784, 0.5), 600);
    },
    beep: () => {
      for (let i = 0; i < 3; i++) {
        setTimeout(() => generateBeep(880, 0.15, 'square'), i * 300);
      }
    },
    chime: () => {
      generateBeep(1047, 0.2);
      setTimeout(() => generateBeep(1319, 0.2), 200);
      setTimeout(() => generateBeep(1568, 0.3), 400);
      setTimeout(() => generateBeep(2093, 0.5), 600);
    },
    alert: () => {
      for (let i = 0; i < 5; i++) {
        setTimeout(() => generateBeep(1000, 0.1, 'sawtooth'), i * 150);
      }
    }
  };

  function playSound(name: string) {
    sounds[name]?.() || sounds.gentle();
  }

  const segmentedBtns = document.querySelectorAll('.segment');
  const views: Record<string, HTMLElement> = {};
  document.querySelectorAll('.view').forEach(v => { views[v.id] = v; });

  const inputH = document.getElementById('input-h') as HTMLInputElement;
  const inputM = document.getElementById('input-m') as HTMLInputElement;
  const inputS = document.getElementById('input-s') as HTMLInputElement;
  const setupLabel = document.getElementById('setup-label') as HTMLInputElement;
  const setupSound = document.getElementById('setup-sound') as HTMLSelectElement;
  const startBtn = document.getElementById('start-btn')!;
  const headerAddBtn = document.getElementById('header-add-btn')!;

  const alarmsGrid = document.getElementById('alarms-grid')!;
  const emptyAlarms = document.getElementById('empty-alarms')!;

  const focusTimeDisplay = document.getElementById('focus-time-display')!;
  const endTimeDisplay = document.getElementById('end-time-display')!;
  const focusLabel = document.getElementById('focus-label')!;
  const ringProgress = document.querySelector('.ring-progress') as SVGCircleElement;
  const focusSoundSelect = document.getElementById('focus-sound-select') as HTMLSelectElement;
  const cancelBtn = document.getElementById('cancel-btn')!;
  const pauseBtn = document.getElementById('pause-btn')!;

  const radius = ringProgress.r.baseVal.value;
  const circumference = radius * 2 * Math.PI;
  ringProgress.style.strokeDasharray = `${circumference} ${circumference}`;

  let activeTimers: any[] = [];
  let focusedTimerId: number | null = null;

  function switchView(viewId: string) {
    Object.values(views).forEach(v => v.classList.remove('active'));
    views[viewId].classList.add('active');
    segmentedBtns.forEach(btn => {
      if (btn.getAttribute('data-target') === viewId) btn.classList.add('active');
      else btn.classList.remove('active');
    });
    if (viewId === 'alarms-view') renderDashboard();
    if (viewId === 'focus-view') updateFocusUI();
  }

  segmentedBtns.forEach(btn => {
    btn.addEventListener('click', () => switchView(btn.getAttribute('data-target')!));
  });
  headerAddBtn.addEventListener('click', () => switchView('timers-view'));

  function formatTime(secs: number) {
    const h = Math.floor(secs / 3600);
    const m = Math.floor((secs % 3600) / 60);
    const s = secs % 60;
    if (h > 0) return `${h}:${m.toString().padStart(2, '0')}:${s.toString().padStart(2, '0')}`;
    return `${m.toString().padStart(2, '0')}:${s.toString().padStart(2, '0')}`;
  }

  function calcEndTime(remainingSeconds: number) {
    const now = new Date();
    now.setSeconds(now.getSeconds() + remainingSeconds);
    let h = now.getHours(), m = now.getMinutes();
    const ampm = h >= 12 ? 'PM' : 'AM';
    h = h % 12; h = h ? h : 12;
    m = m < 10 ? 0 + m : m;
    return `${h}:${m} ${ampm}`;
  }

  function tickAll() {
    let needsRender = false;
    activeTimers.forEach(t => {
      if (t.isRunning && t.remaining > 0) {
        t.remaining--;
        needsRender = true;
        if (t.remaining <= 0) {
          t.isRunning = false;
          t.isFinished = true;
          playSound(t.sound);
        } else {
          t.expectedEnd = calcEndTime(t.remaining);
        }
      }
    });
    if (needsRender || activeTimers.length > 0) {
      if (views['alarms-view'].classList.contains('active')) renderDashboard();
      if (views['focus-view'].classList.contains('active')) updateFocusUI();
    }
  }

  setInterval(tickAll, 1000);

  function renderDashboard() {
    Array.from(alarmsGrid.children).forEach(child => {
      if (child.id !== 'empty-alarms') child.remove();
    });
    if (activeTimers.length === 0) {
      emptyAlarms.style.display = 'flex';
      return;
    }
    emptyAlarms.style.display = 'none';
    activeTimers.forEach(t => {
      const pct = t.total > 0 ? t.remaining / t.total : 0;
      const dashCircum = 2 * Math.PI * 50;
      const offset = dashCircum - pct * dashCircum;
      const card = document.createElement('div');
      card.className = 'dash-card hover-bounce';
      card.innerHTML = `
        <div class="dash-ring-container">
          <svg class="dash-svg">
            <circle class="dash-bg" stroke-width="8" fill="transparent" r="50" cx="55" cy="55"/>
            <circle class="dash-progress" stroke-width="8" fill="transparent" r="50" cx="55" cy="55" style="stroke-dasharray: ${dashCircum}; stroke-dashoffset: ${offset};"/>
          </svg>
          <div class="dash-time-inside">${t.isFinished ? '00:00' : formatTime(t.remaining)}</div>
        </div>
        <div class="dash-label">${t.label || 'Timer'}</div>
        <div class="dash-end">${t.isFinished ? 'Ringing!' : (t.isRunning ? t.expectedEnd : 'Paused')}</div>
      `;
      card.addEventListener('click', () => {
        focusedTimerId = t.id;
        switchView('focus-view');
      });
      alarmsGrid.appendChild(card);
    });
  }

  function updateFocusUI() {
    const t = activeTimers.find(x => x.id === focusedTimerId);
    if (!t) return switchView('alarms-view');
    focusTimeDisplay.textContent = t.isFinished ? '00:00' : formatTime(t.remaining);
    focusLabel.textContent = t.label || 'Timer';
    focusSoundSelect.value = t.sound;
    if (t.isFinished) {
      endTimeDisplay.textContent = "Time's up";
      pauseBtn.style.display = 'none';
    } else {
      pauseBtn.style.display = 'flex';
      pauseBtn.textContent = t.isRunning ? 'Pause' : 'Resume';
      pauseBtn.style.color = t.isRunning ? 'var(--timer-orange)' : '#34C759';
      pauseBtn.style.backgroundColor = t.isRunning ? 'rgba(255, 159, 10, 0.2)' : 'rgba(52, 199, 89, 0.2)';
      endTimeDisplay.textContent = t.isRunning ? t.expectedEnd : 'Paused';
    }
    const pct = t.total > 0 ? t.remaining / t.total : 0;
    ringProgress.style.strokeDashoffset = String(circumference - pct * circumference);
  }

  startBtn.addEventListener('click', () => {
    const h = parseInt(inputH.value) || 0;
    const m = parseInt(inputM.value) || 0;
    const s = parseInt(inputS.value) || 0;
    const total = h * 3600 + m * 60 + s;
    if (total <= 0) return;
    const newTimer = {
      id: Date.now(),
      total, remaining: total,
      isRunning: true, isFinished: false,
      expectedEnd: calcEndTime(total),
      label: setupLabel.value,
      sound: setupSound.value
    };
    activeTimers.push(newTimer);
    inputH.value = ''; inputM.value = ''; inputS.value = '';
    focusedTimerId = newTimer.id;
    switchView('focus-view');
  });

  pauseBtn.addEventListener('click', () => {
    const t = activeTimers.find(x => x.id === focusedTimerId);
    if (!t) return;
    t.isRunning = !t.isRunning;
    if (t.isRunning) t.expectedEnd = calcEndTime(t.remaining);
    updateFocusUI();
  });

  cancelBtn.addEventListener('click', () => {
    const idx = activeTimers.findIndex(x => x.id === focusedTimerId);
    if (idx > -1) activeTimers.splice(idx, 1);
    focusedTimerId = null;
    switchView('alarms-view');
  });

  [inputH, inputM, inputS].forEach(inp => inp.addEventListener('blur', () => {
    if (inp.value.length === 1) inp.value = inp.value.padStart(2, '0');
  }));
</script>