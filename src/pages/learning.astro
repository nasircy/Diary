---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="學習記錄">
  <section>
    <h1>學習記錄</h1>
    <p style="color: var(--color-muted); margin-bottom: 2rem;">記錄我的學習進度，還有一些筆記，幫助我思考。</p>

    <!-- ── TOEIC 不熟單字 ── -->
    <article>
      <details class="lc-card" id="voc-card">
        <summary class="lc-card-summary">
          <div class="lc-card-left">
            <span class="lc-card-icon">📖</span>
            <div>
              <h3 class="lc-card-title">TOEIC 不熟單字</h3>
              <p class="lc-card-desc">背單字刷題，支援多種題型。</p>
            </div>
          </div>
          <span class="lc-card-arrow">›</span>
        </summary>

        <div class="lc-card-body">
          <div id="voc-setup" class="voc-setup">
            <div class="voc-setup-group">
              <label for="voc-day-select" class="voc-setup-label">選擇天數：</label>
              <select id="voc-day-select" class="voc-select"></select>
            </div>
            <div class="voc-setup-group">
              <label for="voc-mode-select" class="voc-setup-label">測驗模式：</label>
              <select id="voc-mode-select" class="voc-select">
                <option value="mixed">隨機混合</option>
                <option value="type-en">輸入英文</option>
                <option value="pick-zh">選擇中文</option>
                <option value="pick-en">選擇英文</option>
              </select>
            </div>
            <div id="voc-status" class="voc-status"></div>
            <button id="voc-start-btn" class="voc-start-btn">開始測驗</button>
          </div>

          <!-- Quiz area -->
          <div id="voc-quiz" class="voc-quiz" style="display:none">
            <div class="voc-quiz-header">
              <span class="voc-quiz-title" id="voc-quiz-title">Day 1</span>
              <div style="display: flex; align-items: center; gap: 0.8rem;">
                <span class="voc-quiz-progress" id="voc-quiz-progress">1 / 20</span>
                <button id="voc-quiz-abort" class="voc-abort-btn">返回</button>
              </div>
            </div>
            <div class="voc-quiz-body" id="voc-quiz-body"></div>
            <div class="voc-quiz-footer">
              <span class="voc-quiz-score" id="voc-quiz-score">✓ 0 &nbsp; ✗ 0</span>
              <button class="voc-quiz-next" id="voc-quiz-next" style="display:none">下一題 →</button>
            </div>
          </div>

          <!-- Result area -->
          <div id="voc-result" class="voc-result" style="display:none"></div>
        </div>
      </details>
    </article>

    <!-- ── Python 線上練習 ── -->
    <article>
      <details class="lc-card" id="py-card">
        <summary class="lc-card-summary">
          <div class="lc-card-left">
            <span class="lc-card-icon">🐍</span>
            <div>
              <h3 class="lc-card-title">Python 線上練習</h3>
              <p class="lc-card-desc">直接在瀏覽器裏跑 Python。</p>
            </div>
          </div>
          <span class="lc-card-arrow">›</span>
        </summary>

        <div class="lc-card-body">
          <div class="py-runner">
            <div class="py-toolbar">
              <span class="py-label">Python</span>
              <button class="py-run-btn" id="py-run-btn" disabled>
                <span class="py-run-icon">▶</span>
                <span id="py-run-text">執行</span>
              </button>
            </div>
            <textarea class="py-editor" id="py-editor" spellcheck="false" placeholder="在這裡寫 Python 程式碼...">print("Hello, World!")</textarea>
            <div class="py-output-header">
              <span class="py-label">輸出</span>
              <span class="py-status" id="py-status">點擊展開後載入…</span>
            </div>
            <pre class="py-output" id="py-output">展開後自動載入 Python 環境。</pre>
          </div>
        </div>
      </details>
    </article>

    <article>
      <p style="color: var(--color-muted);">更多學習分享即將上線。</p>
    </article>
  </section>

  <style is:global>
    .lc-card {
      border: 1px solid var(--color-border);
      border-radius: 14px;
      overflow: hidden;
      margin-bottom: 1.5rem;
      transition: border-color 0.25s, box-shadow 0.25s;
    }
    .lc-card[open] {
      border-color: var(--color-accent);
      box-shadow: 0 4px 24px rgba(74,103,65,0.08);
    }
    .lc-card-summary {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1.1rem 1.4rem;
      cursor: pointer;
      list-style: none;
      transition: background 0.15s;
      user-select: none;
    }
    .lc-card-summary::-webkit-details-marker { display: none; }
    .lc-card-summary::marker { content: ''; }
    .lc-card-summary:hover { background: var(--color-border); }
    .lc-card-left { display: flex; align-items: center; gap: 0.9rem; }
    .lc-card-icon { font-size: 1.6rem; flex-shrink: 0; }
    .lc-card-title {
      font-family: var(--font-heading);
      font-size: 1.1rem;
      font-weight: 600;
      color: var(--color-text);
      margin: 0;
    }
    .lc-card-desc {
      font-size: 0.82rem;
      color: var(--color-muted);
      margin: 0.1rem 0 0;
    }
    .lc-card-arrow {
      font-size: 1.1rem;
      color: var(--color-muted);
      transition: transform 0.25s;
      flex-shrink: 0;
    }
    .lc-card[open] .lc-card-arrow { transform: rotate(90deg); }
    .lc-card-body {
      border-top: 1px solid var(--color-border);
      padding: 1.2rem 1.4rem;
    }

    .voc-setup {
      display: flex;
      flex-direction: column;
      gap: 1.2rem;
      max-width: 400px;
      margin: 1rem auto;
      padding: 1.5rem;
      background: var(--color-bg);
      border: 1px solid var(--color-border);
      border-radius: 12px;
      box-shadow: 0 4px 16px rgba(0, 0, 0, 0.03);
    }
    .voc-setup-group {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }
    .voc-setup-label {
      font-family: var(--font-heading);
      font-size: 0.9rem;
      font-weight: 600;
      color: var(--color-text);
    }
    .voc-select {
      width: 100%;
      padding: 0.65rem 1rem;
      border: 1.5px solid var(--color-border);
      border-radius: 8px;
      background: var(--color-bg);
      color: var(--color-text);
      font-family: var(--font-heading);
      font-size: 0.95rem;
      outline: none;
      cursor: pointer;
      transition: border-color 0.2s;
    }
    .voc-select:focus {
      border-color: var(--color-accent);
    }
    .voc-start-btn {
      width: 100%;
      padding: 0.75rem;
      background: var(--color-accent);
      color: #fff;
      border: none;
      border-radius: 8px;
      font-family: var(--font-heading);
      font-size: 0.95rem;
      font-weight: 600;
      cursor: pointer;
      transition: opacity 0.15s, transform 0.1s;
      text-align: center;
      margin-top: 0.5rem;
    }
    .voc-start-btn:hover {
      opacity: 0.9;
      transform: translateY(-1px);
    }
    .voc-start-btn:active {
      transform: translateY(0);
    }
    .voc-status {
      font-size: 0.82rem;
      color: var(--color-muted);
      line-height: 1.5;
      text-align: center;
      background: var(--color-border);
      padding: 0.6rem 0.8rem;
      border-radius: 8px;
      margin-top: 0.25rem;
    }
    .voc-day-loading {
      padding: 2rem;
      text-align: center;
      font-size: 0.9rem;
      color: var(--color-muted);
      font-family: var(--font-heading);
    }

    .voc-quiz {
      border: 1px solid var(--color-border);
      border-radius: 12px;
      overflow: hidden;
    }
    .voc-quiz-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0.75rem 1.1rem;
      background: var(--color-border);
      border-bottom: 1px solid var(--color-border);
    }
    .voc-abort-btn {
      padding: 0.25rem 0.6rem;
      background: none;
      border: 1px solid var(--color-border);
      border-radius: 4px;
      color: var(--color-muted);
      font-family: var(--font-heading);
      font-size: 0.75rem;
      cursor: pointer;
      transition: border-color 0.15s, color 0.15s;
    }
    .voc-abort-btn:hover {
      border-color: var(--color-accent);
      color: var(--color-text);
    }
    .voc-quiz-title {
      font-family: var(--font-heading);
      font-size: 0.9rem;
      font-weight: 600;
      color: var(--color-text);
    }
    .voc-quiz-progress {
      font-family: var(--font-heading);
      font-size: 0.78rem;
      color: var(--color-accent);
      font-weight: 600;
    }
    .voc-quiz-body {
      padding: 1.5rem 1.2rem;
      min-height: 180px;
    }
    .voc-question-type {
      display: inline-block;
      font-size: 0.68rem;
      font-family: var(--font-heading);
      font-weight: 700;
      color: var(--color-bg);
      background: var(--color-accent);
      border-radius: 4px;
      padding: 0.15rem 0.5rem;
      margin-bottom: 0.85rem;
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }
    .voc-question-word {
      font-family: var(--font-heading);
      font-size: 1.8rem;
      font-weight: 700;
      color: var(--color-text);
      margin-bottom: 0.4rem;
      line-height: 1.3;
    }
    .voc-question-hint {
      font-size: 0.82rem;
      color: var(--color-muted);
      margin-bottom: 1rem;
    }
    .voc-input-row { display: flex; gap: 0.6rem; }
    .voc-input {
      flex: 1;
      padding: 0.65rem 1rem;
      border: 1.5px solid var(--color-border);
      border-radius: 8px;
      background: var(--color-bg);
      color: var(--color-text);
      font-family: var(--font-heading);
      font-size: 0.95rem;
      outline: none;
      transition: border-color 0.2s, box-shadow 0.2s;
    }
    .voc-input:focus {
      border-color: var(--color-accent);
      box-shadow: 0 0 0 3px rgba(74,103,65,0.1);
    }
    .voc-input.correct { border-color: #4caf50; background: rgba(76,175,80,0.07); }
    .voc-input.wrong { border-color: #e53935; background: rgba(229,57,53,0.07); }
    .voc-submit-btn {
      padding: 0.65rem 1.2rem;
      background: var(--color-accent);
      color: #fff;
      border: none;
      border-radius: 8px;
      font-family: var(--font-heading);
      font-size: 0.88rem;
      font-weight: 600;
      cursor: pointer;
      white-space: nowrap;
      transition: opacity 0.15s, transform 0.1s;
    }
    .voc-submit-btn:hover { opacity: 0.88; transform: translateY(-1px); }
    .voc-choices {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.65rem;
    }
    .voc-choice {
      padding: 0.85rem 1rem;
      border: 1.5px solid var(--color-border);
      border-radius: 10px;
      background: var(--color-bg);
      color: var(--color-text);
      font-family: var(--font-body);
      font-size: 0.92rem;
      cursor: pointer;
      transition: border-color 0.15s, background 0.15s, transform 0.1s;
      text-align: left;
      line-height: 1.5;
    }
    .voc-choice:hover:not(.chosen) {
      border-color: var(--color-accent);
      background: rgba(74,103,65,0.05);
      transform: translateY(-1px);
    }
    .voc-choice.correct-choice { border-color: #4caf50; background: rgba(76,175,80,0.08); color: #388e3c; font-weight: 600; }
    .voc-choice.wrong-choice { border-color: #e53935; background: rgba(229,57,53,0.08); color: #c62828; }
    .voc-choice.chosen { pointer-events: none; }
    .voc-feedback {
      margin-top: 1rem;
      padding: 0.7rem 1rem;
      border-radius: 8px;
      font-size: 0.88rem;
      font-family: var(--font-heading);
      font-weight: 500;
    }
    .voc-feedback.correct-fb { background: rgba(76,175,80,0.08); color: #388e3c; border-left: 3px solid #4caf50; }
    .voc-feedback.wrong-fb { background: rgba(229,57,53,0.08); color: #c62828; border-left: 3px solid #e53935; }
    .voc-quiz-footer {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0.65rem 1.1rem;
      border-top: 1px solid var(--color-border);
      background: var(--color-border);
    }
    .voc-quiz-score { font-family: var(--font-heading); font-size: 0.82rem; color: var(--color-muted); font-weight: 500; }
    .voc-quiz-next {
      padding: 0.4rem 1rem;
      background: var(--color-accent);
      color: #fff;
      border: none;
      border-radius: 8px;
      font-family: var(--font-heading);
      font-size: 0.82rem;
      font-weight: 600;
      cursor: pointer;
      transition: opacity 0.15s;
    }
    .voc-quiz-next:hover { opacity: 0.88; }

    .voc-result {
      text-align: center;
      padding: 2rem 1.2rem;
      border: 1px solid var(--color-border);
      border-radius: 12px;
    }
    .voc-result-title { font-family: var(--font-heading); font-size: 1rem; color: var(--color-muted); margin-bottom: 0.5rem; }
    .voc-result-score { font-size: 3rem; font-weight: 700; font-family: var(--font-heading); color: var(--color-accent); line-height: 1; margin-bottom: 0.25rem; }
    .voc-result-pct { font-size: 0.95rem; color: var(--color-muted); font-family: var(--font-heading); margin-bottom: 1.5rem; }
    .voc-result-detail { text-align: left; margin-bottom: 1.5rem; border: 1px solid var(--color-border); border-radius: 8px; overflow: hidden; }
    .voc-result-word { display: flex; justify-content: space-between; align-items: center; padding: 0.5rem 0.85rem; border-bottom: 1px solid var(--color-border); font-size: 0.88rem; gap: 1rem; }
    .voc-result-word:last-child { border-bottom: none; }
    .voc-result-word .wrong-word { color: #c62828; font-weight: 600; }
    .voc-result-word .correct-word { color: #388e3c; }
    .voc-back-btn {
      padding: 0.6rem 1.5rem;
      background: var(--color-accent);
      color: #fff;
      border: none;
      border-radius: 8px;
      font-family: var(--font-heading);
      font-size: 0.9rem;
      font-weight: 600;
      cursor: pointer;
      transition: opacity 0.15s, transform 0.1s;
    }
    .voc-back-btn:hover { opacity: 0.88; transform: translateY(-1px); }

    .py-runner { border: 1px solid var(--color-border); border-radius: 12px; overflow: hidden; }
    .py-toolbar { display: flex; align-items: center; justify-content: space-between; padding: 0.55rem 0.9rem; background: var(--color-border); border-bottom: 1px solid var(--color-border); }
    .py-label { font-family: var(--font-heading); font-size: 0.78rem; color: var(--color-muted); letter-spacing: 0.04em; font-weight: 600; }
    .py-run-btn { display: flex; align-items: center; gap: 0.35rem; padding: 0.35rem 0.9rem; background: var(--color-accent); color: #fff; border: none; border-radius: 6px; font-family: var(--font-heading); font-size: 0.8rem; font-weight: 600; cursor: pointer; transition: opacity 0.15s; }
    .py-run-btn:disabled { opacity: 0.45; cursor: not-allowed; }
    .py-run-btn:not(:disabled):hover { opacity: 0.88; }
    .py-run-icon { font-size: 0.65rem; }
    .py-editor { width: 100%; min-height: 220px; padding: 1rem; background: var(--color-bg); color: var(--color-text); border: none; font-family: 'Cascadia Code', 'Fira Code', 'Consolas', monospace; font-size: 0.85rem; line-height: 1.7; resize: vertical; outline: none; tab-size: 4; }
    .py-editor::placeholder { color: var(--color-muted); opacity: 0.6; }
    .py-output-header { display: flex; align-items: center; justify-content: space-between; padding: 0.4rem 0.9rem; background: var(--color-border); border-top: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border); }
    .py-status { font-size: 0.7rem; font-family: var(--font-heading); color: var(--color-muted); }
    .py-output { padding: 1rem; min-height: 80px; max-height: 300px; overflow-y: auto; background: var(--color-bg); color: var(--color-text); font-family: 'Cascadia Code', 'Fira Code', 'Consolas', monospace; font-size: 0.85rem; line-height: 1.7; white-space: pre-wrap; word-break: break-all; margin: 0; }
    .py-output.has-error { color: #c62828; }
    .py-output.running { color: var(--color-muted); }

    @media (max-width: 640px) {
      .voc-choices { grid-template-columns: 1fr; }
      .voc-day-list { grid-template-columns: repeat(auto-fill, minmax(130px, 1fr)); }
      .voc-question-word { font-size: 1.4rem; }
    }
  </style>



  <script>
    /* ============================================================
       TOEIC VOC Quiz
       ============================================================ */
    (function () {
      const VOC_BASE = '/Diary/voc/';
      const STORAGE_KEY = 'toeic-voc-history';
      const MAX_DAY = 365;

      const setupEl = document.getElementById('voc-setup')!;
      const daySelectEl = document.getElementById('voc-day-select') as HTMLSelectElement;
      const modeSelectEl = document.getElementById('voc-mode-select') as HTMLSelectElement;
      const statusEl = document.getElementById('voc-status')!;
      const startBtn = document.getElementById('voc-start-btn') as HTMLButtonElement;
      const quizEl = document.getElementById('voc-quiz')!;
      const quizTitle = document.getElementById('voc-quiz-title')!;
      const quizProgress = document.getElementById('voc-quiz-progress')!;
      const quizBody = document.getElementById('voc-quiz-body')!;
      const quizScore = document.getElementById('voc-quiz-score')!;
      const quizNext = document.getElementById('voc-quiz-next')! as HTMLButtonElement;
      const quizAbortBtn = document.getElementById('voc-quiz-abort') as HTMLButtonElement;
      const resultEl = document.getElementById('voc-result')!;
      const vocCard = document.getElementById('voc-card') as HTMLDetailsElement;

      let allDays: number[] = [];
      let currentWords: { en: string; zh: string }[] = [];
      let currentDay = 0;
      let qIndex = 0;
      let correct = 0;
      let wrong = 0;
      let answered = false;
      let wrongWords: { en: string; zh: string }[] = [];

      function loadHistory(): Record<number, { correct: number; wrong: number; date: string }> {
        try { return JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}'); } catch { return {}; }
      }
      function saveHistory(day: number, c: number, w: number) {
        const h = loadHistory();
        h[day] = { correct: c, wrong: w, date: new Date().toISOString().slice(0, 10) };
        localStorage.setItem(STORAGE_KEY, JSON.stringify(h));
      }

      const TESTED_KEY = 'toeic-voc-tested';
      function loadTestedWords(day: number): string[] {
        try {
          const all = JSON.parse(localStorage.getItem(TESTED_KEY) || '{}');
          return all[day] || [];
        } catch {
          return [];
        }
      }
      function saveTestedWords(day: number, list: string[]) {
        try {
          const all = JSON.parse(localStorage.getItem(TESTED_KEY) || '{}');
          all[day] = list;
          localStorage.setItem(TESTED_KEY, JSON.stringify(all));
        } catch {}
      }

      async function updateDayStatus() {
        const day = parseInt(daySelectEl.value);
        if (!day) {
          statusEl.textContent = '';
          return;
        }
        try {
          const r = await fetch(VOC_BASE + `day${day}.json`);
          const data = await r.json();
          const total = data.words.length;
          const tested = loadTestedWords(day);
          const remaining = total - tested.length;
          statusEl.innerHTML = `此天數共有 <strong>${total}</strong> 個單字，目前這一輪還剩 <strong>${remaining}</strong> 個未測試。`;
        } catch {
          statusEl.textContent = '';
        }
      }

      async function discoverDays() {
        daySelectEl.innerHTML = '<option value="">載入中…</option>';
        try {
          const r = await fetch(VOC_BASE + 'manifest.json');
          const data = await r.json();
          allDays = data.days || [];
        } catch {
          allDays = [];
        }
        renderDayList();
      }

      function renderDayList() {
        if (!allDays.length) {
          daySelectEl.innerHTML = '<option value="">無可用單字檔</option>';
          startBtn.disabled = true;
          statusEl.textContent = '';
          return;
        }
        const hist = loadHistory();
        daySelectEl.innerHTML = allDays.map(d => {
          const h = hist[d];
          const badge = h ? ` (✓${h.correct} ✗${h.wrong})` : '';
          return `<option value="${d}">TOEIC VOC DAY ${d}${badge}</option>`;
        }).join('');
        startBtn.disabled = false;
        updateDayStatus();
      }

      async function startQuiz(day: number) {
        currentDay = day;
        let data;
        try {
          const r = await fetch(VOC_BASE + `day${day}.json`);
          data = await r.json();
        } catch {
          alert('載入失敗。');
          return;
        }
        qIndex = 0; correct = 0; wrong = 0; wrongWords = [];
        
        let tested = loadTestedWords(day);
        let pool = data.words.filter(w => !tested.includes(w.en.toLowerCase()));
        let chosenWords = [];
        
        if (pool.length >= 40) {
          shuffle(pool);
          chosenWords = pool.slice(0, 40);
          tested = [...tested, ...chosenWords.map(w => w.en.toLowerCase())];
          saveTestedWords(day, tested);
        } else {
          chosenWords = [...pool];
          shuffle(chosenWords);
          tested = [];
          const needed = Math.min(40, data.words.length) - chosenWords.length;
          if (needed > 0) {
            const justChoseEn = chosenWords.map(w => w.en.toLowerCase());
            let freshPool = data.words.filter(w => !justChoseEn.includes(w.en.toLowerCase()));
            shuffle(freshPool);
            const topUp = freshPool.slice(0, needed);
            chosenWords = [...chosenWords, ...topUp];
            tested = topUp.map(w => w.en.toLowerCase());
          }
          saveTestedWords(day, tested);
        }
        
        currentWords = chosenWords;
        setupEl.style.display = 'none';
        resultEl.style.display = 'none';
        quizEl.style.display = 'block';
        quizNext.style.display = 'none';
        renderQuestion();
      }

      function renderQuestion() {
        if (qIndex >= currentWords.length) { showResult(); return; }
        answered = false;
        quizTitle.textContent = `TOEIC VOC DAY ${currentDay}`;
        quizProgress.textContent = `${qIndex + 1} / ${currentWords.length}`;
        quizScore.textContent = `✓ ${correct}  ✗ ${wrong}`;
        quizNext.style.display = 'none';

        const word = currentWords[qIndex];
        const selectedMode = modeSelectEl.value;
        let mode = 0;
        if (selectedMode === 'mixed') {
          mode = Math.floor(Math.random() * 3);
        } else if (selectedMode === 'type-en') {
          mode = 0;
        } else if (selectedMode === 'pick-zh') {
          mode = 1;
        } else if (selectedMode === 'pick-en') {
          mode = 2;
        }

        if (mode === 0) {
          renderTypeEn(word);
        } else if (mode === 1) {
          renderPickZhFromEn(word);
        } else {
          renderPickEnFromZh(word);
        }
      }

      function renderTypeEn(word: { en: string; zh: string }) {
        quizBody.innerHTML = `
          <div class="voc-question-type">輸入英文</div>
          <div class="voc-question-word">${word.zh}</div>
          <div class="voc-question-hint">請打出正確的英文單字</div>
          <div class="voc-input-row">
            <input class="voc-input" id="voc-answer" type="text" autocomplete="off" spellcheck="false" placeholder="輸入英文…" />
            <button class="voc-submit-btn" id="voc-submit">確認</button>
          </div>
          <div id="voc-feedback"></div>
        `;
        const input = document.getElementById('voc-answer') as HTMLInputElement;
        const submitBtn = document.getElementById('voc-submit') as HTMLButtonElement;
        const fb = document.getElementById('voc-feedback')!;

        function checkAnswer() {
          if (answered) return;
          answered = true;
          const ans = input.value.trim().toLowerCase();
          const correctAns = word.en.toLowerCase();
          if (ans === correctAns) {
            correct++;
            input.classList.add('correct');
            fb.innerHTML = `<div class="voc-feedback correct-fb">✓ 正確！</div>`;
          } else {
            wrong++;
            wrongWords.push(word);
            input.classList.add('wrong');
            fb.innerHTML = `<div class="voc-feedback wrong-fb">✗ 答案：${word.en}</div>`;
          }
          quizScore.textContent = `✓ ${correct}  ✗ ${wrong}`;
          submitBtn.style.display = 'none';
          input.disabled = true;
          quizNext.style.display = 'inline-block';
        }

        submitBtn.addEventListener('click', checkAnswer);
        input.addEventListener('keydown', e => { if (e.key === 'Enter') checkAnswer(); });
        input.focus();
      }

      function renderPickZhFromEn(word: { en: string; zh: string }) {
        const options = pickDistractors(word, 'zh');
        quizBody.innerHTML = `
          <div class="voc-question-type">選中文</div>
          <div class="voc-question-word">${word.en}</div>
          <div class="voc-choices">${options.map(o => `<button class="voc-choice" data-val="${o}">${o}</button>`).join('')}</div>
          <div id="voc-feedback"></div>
        `;
        bindChoices(word, 'zh');
      }

      function renderPickEnFromZh(word: { en: string; zh: string }) {
        const options = pickDistractors(word, 'en');
        quizBody.innerHTML = `
          <div class="voc-question-type">選英文</div>
          <div class="voc-question-word">${word.zh}</div>
          <div class="voc-choices">${options.map(o => `<button class="voc-choice" data-val="${o}">${o}</button>`).join('')}</div>
          <div id="voc-feedback"></div>
        `;
        bindChoices(word, 'en');
      }

      function pickDistractors(word: { en: string; zh: string }, field: 'en' | 'zh'): string[] {
        const pool = currentWords.filter(w => w[field] !== word[field]);
        shuffle(pool);
        const distractors = pool.slice(0, 3).map(w => w[field]);
        const options = [...distractors, word[field]];
        shuffle(options);
        return options;
      }

      function bindChoices(word: { en: string; zh: string }, field: 'en' | 'zh') {
        const fb = document.getElementById('voc-feedback')!;
        quizBody.querySelectorAll('.voc-choice').forEach(btn => {
          btn.addEventListener('click', () => {
            if (answered) return;
            answered = true;
            const val = (btn as HTMLElement).dataset.val!;
            const correctVal = word[field];
            (btn as HTMLElement).classList.add('chosen');

            if (val === correctVal) {
              correct++;
              (btn as HTMLElement).classList.add('correct-choice');
              fb.innerHTML = `<div class="voc-feedback correct-fb">✓ 正確！</div>`;
            } else {
              wrong++;
              wrongWords.push(word);
              (btn as HTMLElement).classList.add('wrong-choice');
              // highlight correct
              quizBody.querySelectorAll('.voc-choice').forEach(c => {
                if ((c as HTMLElement).dataset.val === correctVal) c.classList.add('correct-choice');
              });
              fb.innerHTML = `<div class="voc-feedback wrong-fb">✗ 正確答案已標示</div>`;
            }
            quizScore.textContent = `✓ ${correct}  ✗ ${wrong}`;
            quizNext.style.display = 'inline-block';
          });
        });
      }

      function showResult() {
        quizEl.style.display = 'none';
        resultEl.style.display = 'block';
        saveHistory(currentDay, correct, wrong);

        const total = currentWords.length;
        const pct = Math.round((correct / total) * 100);
        let detailHTML = '';
        if (wrongWords.length) {
          detailHTML = `<div class="voc-result-detail">${wrongWords.map(w =>
            `<div class="voc-result-word"><span class="wrong-word">${w.en}</span><span>${w.zh}</span></div>`
          ).join('')}</div>`;
        }

        resultEl.innerHTML = `
          <div class="voc-result-title">TOEIC VOC DAY ${currentDay}</div>
          <div class="voc-result-score">${correct} / ${total}</div>
          <div class="voc-result-pct">正確率 ${pct}%</div>
          ${detailHTML}
          <button class="voc-back-btn" id="voc-back">返回選單</button>
        `;
        (document.getElementById('voc-back') as HTMLButtonElement).addEventListener('click', backToDays);
      }

      function backToDays() {
        quizEl.style.display = 'none';
        resultEl.style.display = 'none';
        setupEl.style.display = '';
        renderDayList();
      }

      startBtn.addEventListener('click', () => {
        const day = parseInt(daySelectEl.value);
        if (day) startQuiz(day);
      });

      quizAbortBtn.addEventListener('click', () => {
        if (confirm('確定要離開本次測驗嗎？')) {
          backToDays();
        }
      });

      quizNext.addEventListener('click', () => { qIndex++; renderQuestion(); });

      daySelectEl.addEventListener('change', updateDayStatus);

      vocCard.addEventListener('toggle', () => {
        if (vocCard.open && !allDays.length) discoverDays();
      });
    })();

    /* ============================================================
       Python Runner
       ============================================================ */
    (function () {
      const pyCard = document.getElementById('py-card') as HTMLDetailsElement;
      const runBtn = document.getElementById('py-run-btn') as HTMLButtonElement;
      const editor = document.getElementById('py-editor') as HTMLTextAreaElement;
      const output = document.getElementById('py-output') as HTMLPreElement;
      const status = document.getElementById('py-status') as HTMLSpanElement;
      const runText = document.getElementById('py-run-text') as HTMLSpanElement;

      let pyodide: any = null;
      let loading = false;
      let loaded = false;

      async function initPyodide() {
        if (pyodide || loading) return;
        loading = true;
        status.textContent = '載入中…';
        output.textContent = '正在下載 Python 執行環境（約 8MB），請稍候…';

        try {
          const script = document.createElement('script');
          script.src = 'https://cdn.jsdelivr.net/pyodide/v0.25.1/full/pyodide.js';
          document.head.appendChild(script);
          await new Promise<void>((resolve, reject) => {
            script.onload = () => resolve();
            script.onerror = () => reject(new Error('Failed to load Pyodide script'));
          });

          // @ts-ignore
          pyodide = await window.loadPyodide();
          loaded = true;
          status.textContent = '已就緒';
          output.textContent = 'Python 環境已就緒，可以開始寫 code 了。';
          runBtn.disabled = false;
        } catch (e: any) {
          status.textContent = '載入失敗';
          output.textContent = 'Python 執行環境載入失敗：' + (e.message || e);
        } finally {
          loading = false;
        }
      }

      async function runCode() {
        if (!pyodide) return;
        const code = editor.value.trim();
        if (!code) return;

        runBtn.disabled = true;
        runText.textContent = '執行中…';
        output.textContent = '';
        output.classList.remove('has-error');
        output.classList.add('running');
        status.textContent = '執行中…';
        await new Promise(r => setTimeout(r, 50));

        try {
          pyodide.runPython(`
import sys
from io import StringIO
_stdout = sys.stdout
stderrCapture = StringIO()
sys.stdout = StringIO()
sys.stderr = stderrCapture
`);
          try {
            pyodide.runPython(code);
          } catch (e: any) {
            const errMsg = e.message || String(e);
            const pythonError = errMsg.replace(/PythonError: Traceback.*?\n/, '').trim();
            output.classList.remove('running');
            output.classList.add('has-error');
            output.textContent = pythonError || errMsg;
            return;
          }
          const stdout = pyodide.runPython('sys.stdout.getvalue()');
          const stderr = pyodide.runPython('stderrCapture.getvalue()');
          pyodide.runPython('sys.stdout = _stdout');
          let result = stdout;
          if (stderr) result += '\n' + stderr;
          output.classList.remove('running');
          output.textContent = result || '（無輸出）';
          status.textContent = '完成';
        } catch (e: any) {
          output.classList.remove('running');
          output.classList.add('has-error');
          output.textContent = e.message || String(e);
          status.textContent = '錯誤';
        } finally {
          runBtn.disabled = false;
          runText.textContent = '執行';
        }
      }

      pyCard.addEventListener('toggle', () => {
        if (pyCard.open && !loaded && !loading) initPyodide();
      });
      runBtn.addEventListener('click', runCode);
      editor.addEventListener('keydown', e => {
        if ((e.ctrlKey || e.metaKey) && e.key === 'Enter') { e.preventDefault(); if (!runBtn.disabled) runCode(); }
        if (e.key === 'Tab') {
          e.preventDefault();
          const s = editor.selectionStart, end = editor.selectionEnd;
          editor.value = editor.value.substring(0, s) + '    ' + editor.value.substring(end);
          editor.selectionStart = editor.selectionEnd = s + 4;
        }
      });
    })();

    /* ============================================================
       Utility
       ============================================================ */
    function shuffle<T>(arr: T[]): T[] {
      for (let i = arr.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [arr[i], arr[j]] = [arr[j], arr[i]];
      }
      return arr;
    }
  </script>
</BaseLayout>
