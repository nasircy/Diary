---
import '../styles/global.css';
const { title } = Astro.props;
const base = '/Diary';
---

<!DOCTYPE html>
<html lang="zh-Hant">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | N-Diary</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=LXGW+WenKai:wght@300;400;700&family=Noto+Serif+TC:wght@400;600;700&display=swap"
    rel="stylesheet"
  />
</head>
<body>
  <header>
    <nav>
      <a href={`${base}/`} class="logo">📖 N-Diary</a>
      <ul>
        <li><a href={`${base}/`}>Blog</a></li>
        <li><a href={`${base}/projects`}>小 Project</a></li>
        <li><a href={`${base}/learning`}>學習分享</a></li>
        <li><a href="https://nasirlin.net" target="_blank" rel="noopener">個人網頁</a></li>
      </ul>
    </nav>
  </header>

  <main>
    <slot />
  </main>

  <footer>
    <p>&copy; 2026 Nasir</p>
  </footer>
</body>
</html>
