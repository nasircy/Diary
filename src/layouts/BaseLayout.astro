---
import '../styles/global.css';
import { ViewTransitions } from 'astro:transitions';
const { title } = Astro.props;
const base = '/Diary';
---

<!DOCTYPE html>
<html lang="zh-Hant">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | N-Diary</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=LXGW+WenKai:wght@300;400;700&family=Noto+Serif+TC:wght@400;600;700&display=swap"
    rel="stylesheet"
  />
  <ViewTransitions />
</head>
<body>
  <!-- Page Transition Overlay -->
  <div class="page-transition" id="pageTransition">
    <div class="transition-content">
      <div class="spinner-ring">
        <div class="ring r1"></div>
        <div class="ring r2"></div>
        <div class="ring r3"></div>
      </div>
      <div class="transition-text">N-Diary</div>
    </div>
  </div>

  <header>
    <nav>
      <a href={`${base}/`} class="logo">📖 N-Diary</a>
      <ul>
        <li><a href={`${base}/`}>Main</a></li>
        <li><a href={`${base}/projects`}>SideProjects</a></li>
        <li><a href={`${base}/learning`}>學習記錄</a></li>
        <li><a href="https://nasirlin.net" target="_blank" rel="noopener">個人網頁</a></li>
      </ul>
      <button class="theme-toggle" id="themeToggle" aria-label="切換深色模式">
        <span class="toggle-track">
          <span class="toggle-thumb"></span>
          <span class="icon-sun">☀️</span>
          <span class="icon-moon">🌙</span>
        </span>
      </button>
    </nav>
  </header>

  <main>
    <slot />
  </main>

  <footer>
    <p>&copy; 2026 Nasir</p>
  </footer>

  <style>
    /* Theme Toggle - Capsule Style */
    .theme-toggle {
      background: var(--color-bg);
      border: 1px solid var(--color-border);
      border-radius: 20px;
      padding: 4px;
      cursor: pointer;
      display: flex;
      align-items: center;
      flex-shrink: 0;
      transition: all 0.3s ease;
    }

    .theme-toggle:hover {
      border-color: var(--color-accent);
    }

    .toggle-track {
      display: flex;
      align-items: center;
      gap: 2px;
      position: relative;
      width: 52px;
      height: 24px;
    }

    .toggle-thumb {
      position: absolute;
      left: 2px;
      width: 20px;
      height: 20px;
      background: var(--color-accent);
      border-radius: 50%;
      transition: transform 0.3s ease;
      z-index: 1;
    }

    body.dark .toggle-thumb {
      transform: translateX(28px);
    }

    .toggle-track span:not(.toggle-thumb) {
      font-size: 0.75rem;
      z-index: 0;
      width: 24px;
      text-align: center;
    }

    .icon-moon { display: none; }
    body.dark .icon-sun { display: none; }
    body.dark .icon-moon { display: inline; }

    /* Page Transition Overlay */
    .page-transition {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: var(--color-bg);
      z-index: 9999;
      display: flex;
      align-items: center;
      justify-content: center;
      opacity: 1;
      transition: opacity 0.5s ease, visibility 0.5s ease;
    }

    .page-transition.hidden {
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
    }

    .transition-content {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 1.5rem;
    }

    .spinner-ring {
      position: relative;
      width: 60px;
      height: 60px;
    }

    .ring {
      position: absolute;
      width: 100%;
      height: 100%;
      border-radius: 50%;
      border: 2px solid transparent;
    }

    .ring.r1 {
      border-top-color: var(--color-accent);
      animation: spin 1.2s cubic-bezier(0.5, 0, 0.5, 1) infinite;
    }

    .ring.r2 {
      width: 80%;
      height: 80%;
      top: 10%;
      left: 10%;
      border-right-color: var(--color-muted);
      animation: spin 1.6s cubic-bezier(0.5, 0, 0.5, 1) infinite reverse;
    }

    .ring.r3 {
      width: 60%;
      height: 60%;
      top: 20%;
      left: 20%;
      border-bottom-color: var(--color-text);
      animation: spin 1s cubic-bezier(0.5, 0, 0.5, 1) infinite;
    }

    @keyframes spin {
      0% { transform: rotate(0deg); }
      100% { transform: rotate(360deg); }
    }

    .transition-text {
      font-family: var(--font-heading);
      font-size: 1.1rem;
      font-weight: 600;
      color: var(--color-text);
      letter-spacing: 0.1em;
      opacity: 0;
      animation: textFade 1s ease 0.3s forwards;
    }

    @keyframes textFade {
      0% { opacity: 0; transform: translateY(8px); }
      100% { opacity: 1; transform: translateY(0); }
    }

    /* Main content fade in */
    main {
      animation: contentFadeIn 0.6s ease 0.4s both;
    }

    @keyframes contentFadeIn {
      from { opacity: 0; transform: translateY(16px); }
      to { opacity: 1; transform: translateY(0); }
    }
  </style>

  <script>
    // Theme toggle
    function initTheme() {
      const saved = localStorage.getItem('theme');
      if (saved === 'dark' || (!saved && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.body.classList.add('dark');
      }
    }

    initTheme();

    document.getElementById('themeToggle')?.addEventListener('click', () => {
      document.body.classList.toggle('dark');
      localStorage.setItem('theme', document.body.classList.contains('dark') ? 'dark' : 'light');
    });

    // Page transition overlay
    const overlay = document.getElementById('pageTransition');

    function showOverlay() {
      overlay?.classList.remove('hidden');
    }

    function hideOverlay() {
      setTimeout(() => {
        overlay?.classList.add('hidden');
      }, 800);
    }

    // Initial page load
    hideOverlay();

    // Intercept nav links for transition
    document.querySelectorAll('nav a[href]').forEach(link => {
      link.addEventListener('click', (e) => {
        const href = (e.currentTarget as HTMLAnchorElement).getAttribute('href');
        if (!href || href.startsWith('http')) return;
        e.preventDefault();
        showOverlay();
        setTimeout(() => {
          window.location.href = href;
        }, 400);
      });
    });

    // Re-apply theme after ViewTransitions swap
    document.addEventListener('astro:after-swap', () => {
      initTheme();
      hideOverlay();
    });
  </script>
</body>
</html>